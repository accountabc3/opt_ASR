{
  "serverInfo": {
    "protocolVersion": "2024-11-05",
    "capabilities": {
      "tools": {
        "listChanged": true
      }
    },
    "serverInfo": {
      "name": "codebase-mcp",
      "version": "1.0.0"
    }
  },
  "tools": [
    {
      "name": "getCodebase",
      "description": "Retrieve the entire codebase as a single text output using RepoMix",
      "inputSchema": {
        "type": "object",
        "properties": {
          "cwd": {
            "type": "string",
            "description": "Current working directory of the codebase (defaults to current dir)"
          },
          "format": {
            "type": "string",
            "enum": [
              "xml",
              "markdown",
              "plain"
            ],
            "description": "Output format (xml, markdown, or plain)",
            "default": "xml"
          },
          "includeFileSummary": {
            "type": "boolean",
            "description": "Include summary of each file",
            "default": true
          },
          "includeDirectoryStructure": {
            "type": "boolean",
            "description": "Include directory structure",
            "default": true
          },
          "removeComments": {
            "type": "boolean",
            "description": "Remove comments from the code",
            "default": false
          },
          "removeEmptyLines": {
            "type": "boolean",
            "description": "Remove empty lines from the code",
            "default": false
          },
          "showLineNumbers": {
            "type": "boolean",
            "description": "Show line numbers",
            "default": true
          },
          "includePatterns": {
            "type": "string",
            "description": "Include patterns (using glob patterns, comma-separated)"
          },
          "ignorePatterns": {
            "type": "string",
            "description": "Ignore patterns (using glob patterns, comma-separated)"
          }
        },
        "additionalProperties": false,
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
    {
      "name": "getRemoteCodebase",
      "description": "Retrieve a remote repository's codebase as a single text output using RepoMix",
      "inputSchema": {
        "type": "object",
        "properties": {
          "repo": {
            "type": "string",
            "description": "GitHub repository URL or shorthand format (e.g., 'username/repo')"
          },
          "format": {
            "type": "string",
            "enum": [
              "xml",
              "markdown",
              "plain"
            ],
            "description": "Output format (xml, markdown, or plain)",
            "default": "xml"
          },
          "includeFileSummary": {
            "type": "boolean",
            "description": "Include summary of each file",
            "default": true
          },
          "includeDirectoryStructure": {
            "type": "boolean",
            "description": "Include directory structure",
            "default": true
          },
          "removeComments": {
            "type": "boolean",
            "description": "Remove comments from the code",
            "default": false
          },
          "removeEmptyLines": {
            "type": "boolean",
            "description": "Remove empty lines from the code",
            "default": false
          },
          "showLineNumbers": {
            "type": "boolean",
            "description": "Show line numbers",
            "default": true
          },
          "includePatterns": {
            "type": "string",
            "description": "Include patterns (using glob patterns, comma-separated)"
          },
          "ignorePatterns": {
            "type": "string",
            "description": "Ignore patterns (using glob patterns, comma-separated)"
          }
        },
        "required": [
          "repo"
        ],
        "additionalProperties": false,
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
    {
      "name": "saveCodebase",
      "description": "Save the codebase to a file using RepoMix",
      "inputSchema": {
        "type": "object",
        "properties": {
          "cwd": {
            "type": "string",
            "description": "Current working directory of the codebase (defaults to current dir)"
          },
          "outputFile": {
            "type": "string",
            "description": "Output file path",
            "default": "repomix-output.txt"
          },
          "format": {
            "type": "string",
            "enum": [
              "xml",
              "markdown",
              "plain"
            ],
            "description": "Output format (xml, markdown, or plain)",
            "default": "xml"
          },
          "includeFileSummary": {
            "type": "boolean",
            "description": "Include summary of each file",
            "default": true
          },
          "includeDirectoryStructure": {
            "type": "boolean",
            "description": "Include directory structure",
            "default": true
          },
          "removeComments": {
            "type": "boolean",
            "description": "Remove comments from the code",
            "default": false
          },
          "removeEmptyLines": {
            "type": "boolean",
            "description": "Remove empty lines from the code",
            "default": false
          },
          "showLineNumbers": {
            "type": "boolean",
            "description": "Show line numbers",
            "default": true
          },
          "includePatterns": {
            "type": "string",
            "description": "Include patterns (using glob patterns, comma-separated)"
          },
          "ignorePatterns": {
            "type": "string",
            "description": "Ignore patterns (using glob patterns, comma-separated)"
          }
        },
        "additionalProperties": false,
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    }
  ]
}
