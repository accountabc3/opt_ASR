{
  "serverInfo": {
    "protocolVersion": "2024-11-05",
    "capabilities": {
      "tools": {
        "listChanged": true
      }
    },
    "serverInfo": {
      "name": "Biome Tools",
      "version": "1.0.0"
    }
  },
  "tools": [
    {
      "name": "biome-lint",
      "description": "Run Biome linting on files",
      "inputSchema": {
        "type": "object",
        "properties": {
          "paths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "File paths to lint"
          },
          "configPath": {
            "type": "string",
            "description": "Path to the Biome configuration file"
          }
        },
        "required": [
          "paths"
        ],
        "additionalProperties": false,
        "$schema": "http://json-schema.org/draft-07/schema#"
      }
    },
    {
      "name": "biome-format",
      "description": "Run Biome formatting on files",
      "inputSchema": {
        "type": "object",
        "properties": {
          "paths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "File paths to format"
          },
          "configPath": {
            "type": "string",
            "description": "Path to the Biome configuration file"
          }
        },
        "required": [
          "paths"
        ],
        "additionalProperties": false,
        "$schema": "http://json-schema.org/draft-07/schema#"
      }
    }
  ]
}
